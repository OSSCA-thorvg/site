---
const base = import.meta.env.BASE_URL;
---
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__col">
        <h3>ThorVG</h3>
        <a href="https://www.thorvg.org" target="_blank" rel="noopener noreferrer" aria-label="ThorVG 공식 사이트 새 창">공식 사이트</a>
        <a href="https://github.com/thorvg/thorvg" target="_blank" rel="noopener noreferrer" aria-label="ThorVG GitHub 새 창">GitHub</a>
      </div>
      <div class="footer__col">
        <h3>OSSCA</h3>
        <a href="https://www.contribution.ac/2026ossca" target="_blank" rel="noopener noreferrer" aria-label="OSSCA 2026 새 창">OSSCA 2026</a>
      </div>
      <div class="footer__col">
        <h3>바로가기</h3>
        <a href={base + 'issues'}>이슈</a>
        <a href={base + 'blog'}>블로그</a>
        <a href={base + 'playground'}>플레이그라운드</a>
        <a href={base + 'schedule'}>일정</a>
        <a href={base + 'thorvg'}>ThorVG 자료</a>
      </div>
    </div>
    <p class="footer__credit">OSSCA 2026 ThorVG 팀의 학습과 기여 기록입니다.</p>
  </div>
</footer>
