---
import { getCollection } from 'astro:content';
import PostListing from '../../components/PostListing.astro';
import { hasAssignmentTag } from '../../lib/post-sections.js';

const posts = (await getCollection(
  'blog',
  ({ data }) => !data.draft && !hasAssignmentTag(data.tags)
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<PostListing
  posts={posts}
  title="블로그"
  active="blog"
  eyebrow="학습 기록"
  lede="ThorVG 학습 내용과 오픈소스 기여 경험, 그리고 다양한 이야기를 나눕니다."
  categoryLabel="블로그"
  itemLabel="글"
  writeLabel="글쓰기"
  writeAriaLabel="GitHub Discussion에서 새 블로그 글쓰기"
/>
