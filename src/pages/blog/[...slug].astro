---
import Base from '../../layouts/Base.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import MermaidDiagrams from '../../components/MermaidDiagrams.astro';
import SeriesList from '../../components/SeriesList.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection, render } from 'astro:content';
import { hasAssignmentTag } from '../../lib/post-sections.js';
import { createSeriesIndex, extractSeriesHeading } from '../../lib/post-series.js';
import { deriveSummary } from '../../lib/summary.js';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const seriesSources = posts.map((post) => ({
    id: post.id,
    title: post.data.title,
    heading: extractSeriesHeading(post.body),
  }));
  const seriesIndex = createSeriesIndex(seriesSources);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, series: seriesIndex.get(post.id) ?? null },
  }));
}

const { post, series } = Astro.props;
const { Content, headings } = await render(post);
const base = import.meta.env.BASE_URL;
const hasToc = headings.some((heading) => heading.depth === 2 || heading.depth === 3);
const assignment = hasAssignmentTag(post.data.tags);
const section = assignment
  ? { active: 'assignments', href: 'assignments', label: '과제' }
  : { active: 'blog', href: 'blog', label: '블로그' };
const fmt = (date: Date) => date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---
<Base title={post.data.title} description={post.data.summary || deriveSummary(post.body ?? '')} active={section.active}>
  <section class="section">
    <div class="container article-container">
      <a class="btn btn--ghost article-back" href={base + section.href}>← {section.label} 목록</a>
      <header class="article-head">
        <h1 class="page-title">{post.data.title}</h1>
        <div class="article-head__meta">
          <a
            class="post-card__author"
            href={`https://github.com/${post.data.github}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`@${post.data.github} GitHub 프로필 (새 창)`}
          >
            <img
              class="author-avatar"
              src={`https://github.com/${post.data.github}.png?size=80`}
              alt=""
              width="32"
              height="32"
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer"
            />
            <span class="post-card__author-copy">
              <span class="post-card__author-name">@{post.data.github}</span>
            </span>
          </a>
          <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
        </div>
        <ul class="article-head__tags" aria-label="태그">
          {post.data.tags.map((t) => <li><span class="chip">#{t}</span></li>)}
        </ul>
      </header>
      {(series || hasToc) && (
        <div class="toc-area">
          <div class="toc-stack">
            {series && <SeriesList series={series} currentId={post.id} />}
            <TableOfContents headings={headings} />
          </div>
        </div>
      )}
      <article class="prose">
        <Content />
      </article>
      <GiscusComments discussionNumber={post.data.discussionNumber} />
    </div>
  </section>

  <MermaidDiagrams />
</Base>
